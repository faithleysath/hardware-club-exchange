# Public runtime variables
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only variables
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
POSTGRES_URL="postgres://postgres:password@db.host.supabase.co:5432/postgres"
POSTGRES_URL_NON_POOLING="postgres://postgres:password@db.host.supabase.co:5432/postgres"

# Optional safety flag: set to true only after Preview is confirmed to use isolated data resources
NEXT_PUBLIC_PREVIEW_DATA_ISOLATED="false"
